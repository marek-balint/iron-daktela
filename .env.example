# Daktela module — DEV configuration sample.
# Copy to ".env" for local development:  cp .env.example .env
# NEVER commit a real .env (see .gitignore). In production these belong in
# PrestaShop Configuration (set via the module's Configure page), not a file.
# Values here override Configuration at runtime (src/Support/ModuleConfig.php)
# so you can run cli/sync.php with no PrestaShop and no Daktela account.

# =====================================================================
# RIGHT NOW: no Daktela key, no Anthropic key, only a Groq key.
# So: mock Daktela (replay fixtures) + Groq for classification.
# =====================================================================

# --- Daktela source ---
# 1 = replay tests/fixtures/*.json instead of calling the live API.
DAKTELA_USE_MOCK=1
# Only needed once you have an instance (https://<instance>.daktela.com/api/v6/,
# NOT www.daktela.com — see docs/03-daktela-integration.md):
DAKTELA_BASE_URL=
DAKTELA_ACCESS_TOKEN=

# --- AI provider ---
# anthropic = Claude (the documented production target, docs/04).
# groq      = OpenAI-compatible; what we use NOW because it's the key we have.
DAKTELA_AI_PROVIDER=groq

# Groq (OpenAI-compatible API). Get a key at https://console.groq.com.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1/
# Model IDs change on Groq — verify yours with:
#   curl https://api.groq.com/openai/v1/models -H "Authorization: Bearer $GROQ_API_KEY"
# Tier 1 = cheap/fast triage; Tier 2 = stronger model for money/complaint/complex.
GROQ_MODEL_TIER1=llama-3.1-8b-instant
GROQ_MODEL_TIER2=llama-3.3-70b-versatile

# Anthropic (used when DAKTELA_AI_PROVIDER=anthropic). Leave blank for now.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1/
ANTHROPIC_MODEL_TIER1=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_TIER2=claude-sonnet-4-6

# --- Scoring (docs/05-prioritization.md) ---
# ai | manual | ai_assisted
DAKTELA_SCORE_MODE=ai
DAKTELA_W_SLA=0.30
DAKTELA_W_VALUE=0.25
DAKTELA_W_SENTIMENT=0.20
DAKTELA_W_CATEGORY=0.15
DAKTELA_W_URGENCY=0.10

# Max tickets processed per sync run (bounded, resumable — docs/03).
DAKTELA_SYNC_MAX=100
# Generate grounded draft replies for simple product questions (docs/04).
DAKTELA_GROUNDING=1
